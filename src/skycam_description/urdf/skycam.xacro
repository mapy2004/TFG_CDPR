<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="skycam">

  <!-- ========================= -->
  <!-- PROPIEDADES -->
  <!-- ========================= -->
  <xacro:property name="stadium_len" value="22.0"/>
  <xacro:property name="stadium_width" value="15.0"/>
  <xacro:property name="stadium_height" value="10.0"/>

  <xacro:property name="p_size" value="0.9"/>
  <xacro:property name="p_mass" value="570.0"/>

  <!-- ========================= -->
  <!-- MATERIALES -->
  <!-- ========================= -->
  <material name="gray">
    <color rgba="0.5 0.5 0.5 1.0"/>
  </material>

  <material name="blue">
    <color rgba="0.0 0.0 0.8 1.0"/>
  </material>

  <material name="red">
    <color rgba="0.8 0.0 0.0 1.0"/>
  </material>

  <!-- ========================= -->
  <!-- WORLD -->
  <!-- ========================= -->
  <link name="world"/>

  <!-- ========================= -->
  <!-- MACRO: POSTES + ANCLAJES -->
  <!-- ========================= -->
  <xacro:macro name="anchor_pole" params="name x y">
    <link name="pole_${name}">
      <visual>
        <geometry>
          <cylinder radius="0.1" length="${stadium_height}"/>
        </geometry>
        <material name="gray"/>
      </visual>
      <collision>
        <geometry>
          <cylinder radius="0.1" length="${stadium_height}"/>
        </geometry>
      </collision>
      <inertial>
        <mass value="1.0"/>
        <inertia ixx="0.01" ixy="0" ixz="0" iyy="0.01" iyz="0" izz="0.01"/>
      </inertial>
    </link>

    <joint name="world_to_pole_${name}" type="fixed">
      <parent link="world"/>
      <child link="pole_${name}"/>
      <origin xyz="${x} ${y} ${stadium_height/2}"/>
    </joint>

    <link name="anchor_${name}">
      <visual>
        <geometry>
          <sphere radius="0.15"/>
        </geometry>
        <material name="red"/>
      </visual>
    </link>

    <joint name="pole_to_anchor_${name}" type="fixed">
      <parent link="pole_${name}"/>
      <child link="anchor_${name}"/>
      <origin xyz="0 0 ${stadium_height/2}"/>
    </joint>
  </xacro:macro>

  <!-- POSTES -->
  <xacro:anchor_pole name="1" x="0" y="0"/>
  <xacro:anchor_pole name="2" x="${stadium_len}" y="0"/>
  <xacro:anchor_pole name="3" x="${stadium_len}" y="${stadium_width}"/>
  <xacro:anchor_pole name="4" x="0" y="${stadium_width}"/>

  <!-- ========================= -->
  <!-- PLATAFORMA -->
  <!-- ========================= -->
  <link name="platform">
    <inertial>
      <mass value="${p_mass}"/>
      <origin xyz="0 0 0"/>
      <inertia
        ixx="38.95" ixy="0" ixz="0"
        iyy="38.95" iyz="0"
        izz="76.95"/>
    </inertial>

    <visual>
      <geometry>
        <box size="${p_size} ${p_size} 0.1"/>
      </geometry>
      <material name="blue"/>
    </visual>

    <collision>
      <geometry>
        <box size="${p_size} ${p_size} 0.1"/>
      </geometry>
    </collision>
  </link>

  <!-- ========================= -->
  <!-- GAZEBO: PLATAFORMA FÍSICA -->
  <!-- ========================= -->
  <gazebo reference="platform">
    <gravity>true</gravity>
    <selfCollide>false</selfCollide>
    <static>false</static>
    <pose>11 7.5 6 0 0 0</pose>

      
    <plugin name="gazebo_ros2_control" filename="libgazebo_ros2_control.so"/>
  
  </gazebo>

  <!-- ========================= -->
  <!-- JOINT SOLO PARA TF / RVIZ -->
  <!-- ========================= -->
  <joint name="world_to_platform" type="floating">
    <parent link="world"/>
    <child link="platform"/>
    <origin xyz="11 7.5 6"/>
  </joint>

  <!-- ========================= -->
  <!-- ANCLAJES EN PLATAFORMA -->
  <!-- ========================= -->
  <xacro:macro name="platform_anchor" params="name x y z">
    <link name="platform_anchor_${name}">
      <visual>
        <geometry>
          <sphere radius="0.05"/>
        </geometry>
        <material name="red"/>
      </visual>
    </link>

    <joint name="platform_to_anchor_${name}" type="fixed">
      <parent link="platform"/>
      <child link="platform_anchor_${name}"/>
      <origin xyz="${x} ${y} ${z}"/>
    </joint>
  </xacro:macro>

  <xacro:platform_anchor name="1" x=" 0.45" y=" 0.45" z="0.05"/>
  <xacro:platform_anchor name="2" x="-0.45" y=" 0.45" z="0.05"/>
  <xacro:platform_anchor name="3" x="-0.45" y="-0.45" z="0.05"/>
  <xacro:platform_anchor name="4" x=" 0.45" y="-0.45" z="0.05"/>

</robot>
